<style>
:root{
    --green:#2e7d32;
    --khaki:#c3b091;
    --white:#ffffff;
    --dark:#121212;
    --light:#f8f9fa;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    scroll-behavior:smooth;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:var(--light);
    color:#333;
}

@media (prefers-color-scheme: dark){
body{
    background:#181818;
    color:white;
}
.section{
    background:#222 !important;
}
}

header{
    position:fixed;
    width:100%;
    top:0;
    background:rgba(46,125,50,0.95);
    z-index:1000;
    padding:15px 0;
}

nav{
    display:flex;
    justify-content:center;
    gap:25px;
    flex-wrap:wrap;
}

nav a{
    color:white;
    text-decoration:none;
    font-weight:600;
    transition:.3s;
}

nav a:hover{
    color:var(--khaki);
}

section{
    min-height:100vh;
    padding:100px 10%;
    display:flex;
    align-items:center;
    justify-content:center;
}

.section{
    width:100%;
    max-width:1200px;
    background:white;
    padding:40px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.1);
}

.hero{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:40px;
    align-items:center;
}

.hero img{
    width:100%;
    max-width:400px;
    border-radius:20px;
    border:5px solid var(--green);
}

.hero-text h1{
    font-size:3rem;
    color:var(--green);
}

.hero-text p{
    margin-top:15px;
    line-height:1.8;
}

.btn{
    display:inline-block;
    margin-top:20px;
    background:var(--green);
    color:white;
    padding:12px 25px;
    border-radius:30px;
    text-decoration:none;
}

h2{
    color:var(--green);
    margin-bottom:20px;
}

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:var(--khaki);
    padding:25px;
    border-radius:15px;
    transition:.3s;
}

.card:hover{
    transform:translateY(-5px);
}

.contact-box{
    text-align:center;
}

footer{
    background:var(--green);
    color:white;
    text-align:center;
    padding:20px;
}

@media(max-width:768px){
.hero{
    grid-template-columns:1fr;
    text-align:center;
}

.hero img{
    margin:auto;
}
}
</style>
</head>
